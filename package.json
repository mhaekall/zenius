{
  "name": "openmenu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/extract-meta.js",
    "build": "vite build",
    "preview": "pnpm run build && wrangler dev",
    "setup:storage": "node scripts/setup-storage.js",
    "seed": "node scripts/seed.js",
    "log": "node scripts/agent-log.js",
    "check": "node scripts/health-check.js",
    "db:sync": "supabase db push && supabase gen types typescript --local > src/types/supabase.ts",
    "db:pull": "supabase db pull",
    "edge:serve": "supabase functions serve og-proxy --env-file ./supabase/.env.local",
    "edge:deploy": "supabase functions deploy og-proxy",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.8",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.533.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.30.1",
    "react-use": "^17.6.0",
    "recharts": "^3.8.0",
    "zod": "^3.25.76",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.27.0",
    "@faker-js/faker": "^10.3.0",
    "@types/matter-js": "^0.20.0",
    "@types/node": "^24.0.14",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.5.2",
    "@youware/vite-plugin-react": "^1.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "supabase": "^2.77.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-ssg": "^0.1.0",
    "wrangler": "^4.72.0"
  }
}
